# Token do bot criado no Discord Developer Portal
DISCORD_TOKEN=

# Application ID do bot
CLIENT_ID=

# Opcional: registra os comandos instantaneamente em um servidor de testes.
# Sem este valor, os comandos são registrados globalmente e podem demorar a aparecer.
GUILD_ID=

# Opcional: caminho para um arquivo de cookies exportado no formato Netscape.
# Pode ser necessário se o YouTube exigir autenticação no ambiente de hospedagem.
YOUTUBE_COOKIES_FILE=
