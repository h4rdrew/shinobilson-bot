{
  "name": "shinobilson-bot",
  "version": "1.0.2",
  "private": true,
  "description": "Bot de música para Discord com integração exclusiva ao YouTube.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "register": "tsx src/register-commands.ts",
    "check": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "dependencies": {
    "@discordjs/voice": "^0.19.2",
    "discord.js": "^14.27.0",
    "dotenv": "^17.2.3",
    "ffmpeg-static": "^5.3.0",
    "opusscript": "^0.1.1",
    "youtube-dl-exec": "^3.1.9"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
